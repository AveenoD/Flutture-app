                $ref: '#/components/schemas/ErrorResponseWithCode'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'

  /api/v1/subscriptions/{id}/cancel:
    post:
      tags:
        - Subscriptions
      summary: Cancel Subscription
      description: Cancels a subscription. Subscription remains active until end_date. Only General Managers can cancel.
      operationId: cancelSubscription
      security:
        - bearerAuth: []
      parameters:
        - name: id
          in: path
          required: true
          description: Subscription ID
          schema:
            type: string
            format: uuid
      requestBody:
        required: false
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CancelSubscriptionRequest'
